# =============================================================================
# APMoE — .gitignore
# Python 3.11+ · uv · hatchling · ruff · mypy · pytest · PyTorch · FastAPI
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# -----------------------------------------------------------------------------
# Distribution / packaging (hatchling / pip / build)
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# -----------------------------------------------------------------------------
# uv
# -----------------------------------------------------------------------------
# uv.lock is intentionally TRACKED for reproducible installs.
# Uncommit the line below only if this is a library (not an application).
# uv.lock
.uv/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# -----------------------------------------------------------------------------
# Coverage & test artefacts
# -----------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
test-results/
junit.xml

# -----------------------------------------------------------------------------
# Ruff
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# Mypy
# -----------------------------------------------------------------------------
.mypy_cache/
*.pyi.d/

# -----------------------------------------------------------------------------
# Pre-commit
# -----------------------------------------------------------------------------
.pre-commit-home/

# -----------------------------------------------------------------------------
# Jupyter / notebooks (if used for experimentation)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Machine-learning artefacts
# -----------------------------------------------------------------------------
# weights/ is intentionally TRACKED — it ships the default pre-trained models
# (keystroke_age_expert.onnx, keystroke_constants.json, face_age_expert.keras,
# full_digraph_index.json). Only ad-hoc / personally trained checkpoints placed
# outside that directory should be ignored (see checkpoints/ below).

# Stray / locally-trained ONNX files at the project root (not the shipped defaults)
*.onnx
# Un-ignore the canonical model directories so git tracks the shipped defaults.
!weights/*.onnx
!src/apmoe/weights/*.onnx

# Experiment tracking
runs/
mlruns/
wandb/
lightning_logs/
checkpoints/

# -----------------------------------------------------------------------------
# Data directories (raw data should not be committed)
# -----------------------------------------------------------------------------
data/
datasets/
raw/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
# VSCode / Cursor
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Docs build output (source docs are tracked; built HTML/PDF are not)
# -----------------------------------------------------------------------------
docs/_build/
docs/site/
site/

# -----------------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------------
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
*.rej
