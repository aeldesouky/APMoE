# APMoE serving environment example
#
# Copy values into your deployment environment as needed. Do not commit real
# secrets. Authentication and authorization are enabled by default, so local
# demos that do not pass a security provider must disable both toggles.

# Framework environment. In production, remote experts require an explicit
# apmoe.security.remote_endpoint_allowlist in config and cannot use ["*"].
APMOE_ENV=development
# APMOE_ENV=production

# Core serving settings
APMOE_SERVING_HOST=0.0.0.0
APMOE_SERVING_PORT=8000
APMOE_SERVING_WORKERS=4
APMOE_SERVING_LOG_LEVEL=info
APMOE_SERVING_CORS_ORIGINS=https://app.example.com

# Optional rate limit. Memory is process-local; Redis is shared across workers
# and nodes. For very strict global limits, Redis or an API gateway is required.
# APMOE_SERVING_RATE_LIMIT=120
APMOE_SERVING_RATE_LIMIT_STORE=memory
# APMOE_SERVING_RATE_LIMIT_STORE=redis
# APMOE_SERVING_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# APMOE_SERVING_RATE_LIMIT_KEY_PREFIX=apmoe:rate:

# Stateless authn/authz toggles. Defaults are true.
APMOE_SERVING_AUTHENTICATION_ENABLED=true
APMOE_SERVING_AUTHORIZATION_ENABLED=true

# Local/demo only: disable both if you call create_api(...) without a provider.
# APMOE_SERVING_AUTHENTICATION_ENABLED=false
# APMOE_SERVING_AUTHORIZATION_ENABLED=false

# JWT provider values for your application wiring. These are examples consumed
# by your code when constructing JWTBearerAuthProvider, not automatic config
# fields parsed by APMoE core.
# APMOE_JWT_SIGNING_KEY=replace-with-secret-or-public-key
# APMOE_JWT_ALGORITHMS=HS256
# APMOE_JWT_ISSUER=https://issuer.example.com
# APMOE_JWT_AUDIENCE=apmoe-api

# Token invalidation. Memory is process-local; Redis shares JWT jti revocation
# across workers and nodes. Redis keys are stored with TTLs matching token expiry.
APMOE_SERVING_TOKEN_INVALIDATION_STORE=memory
# APMOE_SERVING_TOKEN_INVALIDATION_STORE=redis
# APMOE_SERVING_TOKEN_INVALIDATION_REDIS_URL=redis://localhost:6379/0
# APMOE_SERVING_TOKEN_INVALIDATION_KEY_PREFIX=apmoe:jwt:invalid:

# Remote expert hardening is configured in config JSON under apmoe.security and
# experts[].integrity. Keep response caps bounded, pin explicit outbound hosts in
# production, and verify remote model manifests with a public key whose private
# signing key lives outside the model serving runtime.
# Example config fields:
#   apmoe.security.remote_endpoint_allowlist = ["models.example.com", "*.trusted.ai"]
#   apmoe.security.remote_enforce_https = true
#   apmoe.security.remote_allow_private_networks = false
#   apmoe.security.remote_response_max_bytes = 1048576
#   experts[].integrity.manifest_public_key = "$APMOE_REMOTE_MANIFEST_PUBLIC_KEY"
# APMOE_REMOTE_MANIFEST_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."
